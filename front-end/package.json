{
  "name": "front-end",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run codegen && next build",
    "vercel:pull": "npx -y vercel@latest pull --yes --environment=production",
    "vercel:build": "npx -y vercel@latest build --prod",
    "vercel:deploy": "npx -y vercel@latest --prod --yes",
    "vercel:deploy:prebuilt": "npx -y vercel@latest deploy --prebuilt --prod",
    "deploy:prod": "npm run vercel:pull && npm run vercel:deploy",
    "deploy:prod:prebuilt": "npm run vercel:pull && npm run vercel:build && npm run vercel:deploy:prebuilt",
    "start": "next start",
    "lint": "eslint .",
    "test": "node ./scripts/ci-smoke.mjs",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@types/qrcode": "^1.5.6",
    "graphql": "^16.13.1",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
