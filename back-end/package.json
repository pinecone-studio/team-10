{
  "name": "back-end",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "npm run codegen && next build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "test": "node ./scripts/ci-smoke.mjs",
    "test:graphql": "node --experimental-strip-types tests/graphql.slice.test.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:drizzle:generate": "drizzle-kit generate",
    "db:drizzle:push": "drizzle-kit push",
    "db:remote:migrate": "npx wrangler d1 execute team10-backend-db --remote --file ./database/schema.sql"
  },
  "dependencies": {
    "@apollo/server": "^5.1.0",
    "@as-integrations/next": "^4.1.0",
    "@graphql-tools/merge": "^9.1.7",
    "@types/pdfkit": "^0.17.5",
    "drizzle-orm": "^0.44.5",
    "graphql": "^16.11.0",
    "next": "16.1.6",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-resolvers": "^4.4.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.72.0"
  }
}
