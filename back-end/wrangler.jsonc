{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "team10-backend-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "keep_vars": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "team10-backend-db",
      "database_id": "791d560f-40ef-4d79-b69e-9d2a9e09d866"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "team10-assets"
    }
  ]
}
